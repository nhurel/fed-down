{
  "manifest_version": 2,
  "name": "Fed-Down",
  "version": "0.0.1",
  "description": "Ease fediverse interactions between all accounts",
  "icons": {
    "96": "icons/fed-down-96.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "fed-down@hurel.me",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "browser_action": {
    "default_popup": "popup/fed-react.html",
    "default_icon": {
      "96": "icons/fed-down-96.png"
    }
  },
  
  "background": {
    "scripts": [
      "background.js"
    ],
    "persistent": false
  },

  "options_ui": {
    "page": "settings/options.html"
  },
  "permissions": [
    "storage",
    "tabs",
    "notifications",
    "contextMenus"
  ],
  "content_security_policy": "default-src 'self' https://*; script-src 'self'",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/fed-down.js"
      ]
    }
  ]
}